SELECT t.userID, COUNT(DISTINCT a.loID) AS average_activity_count, AVG(a.estimatedDuration) AS average_hours FROM Activity_csod AS a JOIN Transcript_csod AS t ON a.loID = t.userID WHERE a.activityStartDate >= CAST('2025-01-01 00:00:00' AS TIMESTAMP WITH TIME ZONE) AND a.activityStartDate < CAST('2026-01-01 00:00:00' AS TIMESTAMP WITH TIME ZONE) GROUP BY t.userID;
