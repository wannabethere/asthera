What are the average activities per learner and average learning hours per learner for this year?
SELECT AVG(activity_count) AS average_activities_per_learner, AVG(total_time_spent) AS average_learning_hours_per_learner FROM ( SELECT t.userID, COUNT(DISTINCT t.loID) AS activity_count, SUM(CAST(t.timeSpent AS BIGINT)) AS total_time_spent FROM Transcript_csod t JOIN Activity_csod a ON t.loID = a.loID WHERE CAST(t.timeSpent AS BIGINT) IS NOT NULL AND EXTRACT(YEAR FROM CURRENT_DATE) = EXTRACT(YEAR FROM CURRENT_DATE) GROUP BY t.userID) AS learner_stats;

Can you give total learners who consumed more than one activity this year compared to last year, and what is their percentage change in comparison?
WITH current_year AS ( SELECT t.userID, COUNT(t.userID) AS activity_count FROM Transcript_csod t WHERE t.isCompleted = 'true' AND CAST(t.completionDate AS TIMESTAMP WITH TIME ZONE) >= CAST('2023-01-01 00:00:00' AS TIMESTAMP WITH TIME ZONE) AND CAST(t.completionDate AS TIMESTAMP WITH TIME ZONE) < CAST('2024-01-01 00:00:00' AS TIMESTAMP WITH TIME ZONE) GROUP BY t.userID HAVING COUNT(t.userID) > 1), last_year AS ( SELECT t.userID, COUNT(t.userID) AS activity_count FROM Transcript_csod t WHERE t.isCompleted = 'true' AND CAST(t.completionDate AS TIMESTAMP WITH TIME ZONE) >= CAST('2022-01-01 00:00:00' AS TIMESTAMP WITH TIME ZONE) AND CAST(t.completionDate AS TIMESTAMP WITH TIME ZONE) < CAST('2023-01-01 00:00:00' AS TIMESTAMP WITH TIME ZONE) GROUP BY t.userID HAVING COUNT(t.userID) > 1) SELECT COUNT(DISTINCT c.userID) AS current_year_learners, COUNT(DISTINCT l.userID) AS last_year_learners, CASE WHEN COUNT(DISTINCT l.userID) = 0 THEN NULL ELSE (COUNT(DISTINCT c.userID) - COUNT(DISTINCT l.userID)) * 100.0 / COUNT(DISTINCT l.userID) END AS percentage_change FROM current_year c FULL OUTER JOIN last_year l ON c.userID = l.userID;
