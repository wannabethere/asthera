{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Attack Surface Index Heatmap - Business Unit × Environment",
  "description": "Heatmap showing ASI intensity across business units and environments. Enables quick identification of high-risk combinations.",
  "width": 700,
  "height": 500,
  "data": {
    "name": "attack_surface_index"
  },
  "transform": [
    {
      "aggregate": [
        {
          "op": "mean",
          "field": "attack_surface_index",
          "as": "avg_asi"
        },
        {
          "op": "count",
          "as": "asset_count"
        }
      ],
      "groupby": ["business_unit", "env"]
    },
    {
      "filter": "datum.business_unit != null && datum.env != null"
    }
  ],
  "mark": {
    "type": "rect",
    "cornerRadius": 4,
    "stroke": "#fff",
    "strokeWidth": 2
  },
  "encoding": {
    "x": {
      "field": "business_unit",
      "type": "ordinal",
      "title": "Business Unit",
      "axis": {"labelAngle": -45}
    },
    "y": {
      "field": "env",
      "type": "ordinal",
      "title": "Environment",
      "sort": ["prod", "non-prod"]
    },
    "color": {
      "field": "avg_asi",
      "type": "quantitative",
      "title": "Average ASI",
      "scale": {
        "domain": [0, 100],
        "scheme": "redyellowgreen",
        "reverse": true
      },
      "legend": {
        "title": "ASI Score",
        "orient": "right"
      }
    },
    "size": {
      "field": "asset_count",
      "type": "quantitative",
      "title": "Asset Count",
      "legend": {
        "title": "Asset Count",
        "orient": "right"
      }
    },
    "tooltip": [
      {"field": "business_unit", "type": "nominal", "title": "Business Unit"},
      {"field": "env", "type": "nominal", "title": "Environment"},
      {"field": "avg_asi", "type": "quantitative", "title": "Average ASI", "format": ".1f"},
      {"field": "asset_count", "type": "quantitative", "title": "Asset Count"}
    ]
  },
  "config": {
    "view": {
      "stroke": "transparent"
    }
  }
}

