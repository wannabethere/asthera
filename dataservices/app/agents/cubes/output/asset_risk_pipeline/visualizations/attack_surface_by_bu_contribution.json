{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Top 5 Business Units by Risk Exposure - Contribution Chart",
  "description": "Shows risk contribution percentage of top 5 business units. Pie/Donut chart with risk_contribution_pct.",
  "width": 600,
  "height": 600,
  "data": {
    "name": "attack_surface_by_bu"
  },
  "transform": [
    {
      "window": [{"op": "rank", "as": "rank"}],
      "sort": [{"field": "total_risk_exposure", "order": "desc"}]
    },
    {
      "filter": "datum.rank <= 5"
    },
    {
      "calculate": "datum.total_risk_exposure",
      "as": "risk_value"
    }
  ],
  "mark": {
    "type": "arc",
    "innerRadius": 100,
    "cornerRadius": 5,
    "stroke": "#fff",
    "strokeWidth": 2
  },
  "encoding": {
    "theta": {
      "field": "risk_contribution_pct",
      "type": "quantitative",
      "stack": true,
      "title": "Risk Contribution (%)"
    },
    "color": {
      "field": "business_unit",
      "type": "nominal",
      "title": "Business Unit",
      "scale": {
        "scheme": "category10"
      },
      "legend": {
        "orient": "right",
        "titleFontSize": 14
      }
    },
    "tooltip": [
      {"field": "business_unit", "type": "nominal", "title": "Business Unit"},
      {"field": "total_risk_exposure", "type": "quantitative", "title": "Total Risk Exposure", "format": ".1f"},
      {"field": "risk_contribution_pct", "type": "quantitative", "title": "Contribution %", "format": ".1f"},
      {"field": "avg_asi", "type": "quantitative", "title": "Avg ASI", "format": ".1f"},
      {"field": "high_risk_assets", "type": "quantitative", "title": "High Risk Assets"}
    ]
  }
}

