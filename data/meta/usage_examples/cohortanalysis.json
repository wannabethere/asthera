      "query": "Segment customers by their purchase frequency into high, medium, and low value groups",
      "function": "form_behavioral_cohorts",
      "category": "cohort_analysis",
      "inputs": {
        "behavior_column": "purchases_count",
        "cohort_column": "purchase_frequency_segment",
        "conditions": {
          "High Value": "purchases_count > 10",
          "Medium Value": "purchases_count >= 3 and purchases_count <= 10",
          "Low Value": "purchases_count < 3"
        }
      },
      "patterns": {
        "function_patterns": [
          "(segment|cluster|group) (users|customers)"
        ]
      }
