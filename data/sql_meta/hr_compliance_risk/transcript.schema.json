  "relationships": [
    {
      "name": "transcript_to_activity",
      "models": [
        "transcript",
        "activities"
      ],
      "joinType": "MANY_TO_ONE",
      "condition": "transcript.LOID = activities.lo_id",
      "properties": {
        "purpose": "Get course details"
      }
    },
    {
      "name": "transcript_to_user",
      "models": [
        "transcript",
        "users"
      ],
      "joinType": "MANY_TO_ONE",
      "condition": "transcript.UserId = users.userId",
      "properties": {
        "purpose": "Get user demographics"
      }
    }
  ]
