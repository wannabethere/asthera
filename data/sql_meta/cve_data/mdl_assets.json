            }
          },
          {
            "name": "device_subtype",
            "type": "VARCHAR",
            "properties": {
              "displayName": "Device Subtype",
              "description": "Device subtype classification"
            }
          },
          {
            "name": "platform",
            "type": "VARCHAR",
            "properties": {
              "displayName": "Platform",
              "description": "Device platform"
            }
          },
          {
            "name": "manufacturer",
            "type": "VARCHAR",
            "properties": {
              "displayName": "Manufacturer",
              "description": "Device manufacturer"
            }
          },
          {
            "name": "system_manufacturer",
            "type": "VARCHAR",
            "properties": {
              "displayName": "System Manufacturer",
              "description": "System manufacturer"
            }
          },
          {
            "name": "system_model",
            "type": "VARCHAR",
            "properties": {
              "displayName": "System Model",
              "description": "System model identifier"
            }
          },
          {
            "name": "serial_number",
            "type": "VARCHAR",
            "properties": {
