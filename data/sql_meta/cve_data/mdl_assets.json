      "primaryKey": "nuid",
      "properties": {
        "displayName": "IT Assets",
        "description": "Comprehensive IT asset inventory with security risk assessments, hardware specifications, and location data",
        "queryPatterns": [
          "Find assets by IP address, MAC address, or hostname",
          "Filter assets by device type, manufacturer, or location",
          "Identify assets by OS version or platform",
          "Search for cloud assets or bastion devices",
          "Filter assets by security status (secure boot, domain joined)"
        ],
        "useCases": [
          "Asset Inventory Management: Maintain comprehensive inventory of all IT assets across the organization",
          "Security Risk Assessment: Identify assets with security vulnerabilities or misconfigurations",
          "Compliance Reporting: Generate reports on asset configurations and security posture",
          "Network Segmentation: Analyze asset distribution across network zones and locations",
          "Hardware Lifecycle Management: Track asset age, retirement status, and hardware specifications"
        ]
      },
      "relationships": [
        {
          "name": "asset_agent_relationship",
          "models": [
            "dev_assets",
            "dev_agents"
          ],
          "joinType": "ONE_TO_MANY",
          "condition": "dev_assets.dev_id = dev_agents.dev_id AND dev_assets.nuid = dev_agents.nuid",
          "properties": {
            "displayName": "Asset to Agent Relationship",
            "description": "Relationship between assets and their monitoring agents"
          }
        },
        {
          "name": "asset_to_software_relationship",
          "models": [
            "dev_assets",
            "dev_software_instances"
          ],
          "joinType": "ONE_TO_MANY",
          "condition": "dev_assets.dev_id = dev_software_instances.dev_id AND dev_assets.nuid = dev_software_instances.nuid",
          "properties": {
            "displayName": "Asset to Software Relationship",
            "description": "Relationship between assets and their installed software instances"
          }
        },
        {
          "name": "asset_to_vulnerability_relationship",
          "models": [
            "dev_assets",
            "dev_vulnerability_instances"
          ],
          "joinType": "ONE_TO_MANY",
          "condition": "dev_assets.dev_id = dev_vulnerability_instances.dev_id AND dev_assets.nuid = dev_vulnerability_instances.nuid",
          "properties": {
            "displayName": "Asset to Vulnerability Relationship",
            "description": "Relationship between assets and their vulnerability instances"
