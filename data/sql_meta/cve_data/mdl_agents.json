{
  "catalog": "security_monitoring",
  "schema": "public",
  "models": [
    {
      "name": "dev_agents",
      "description": "Security monitoring agents deployed across the infrastructure for data collection and monitoring",
      "tableReference": {
        "table": "dev_agents"
      },
      "columns": [
        {
          "name": "agent",
          "type": "VARCHAR",
          "properties": {
            "displayName": "Agent",
            "description": "Name or identifier of the security monitoring agent"
          }
        },
        {
          "name": "display_source",
          "type": "VARCHAR",
          "properties": {
            "displayName": "Display Source",
            "description": "Human-readable source name for the agent"
          }
        },
        {
          "name": "ref_source_id",
          "type": "FLOAT",
          "properties": {
            "displayName": "Reference Source ID",
            "description": "Reference identifier linking to the source system"
          }
        },
        {
          "name": "first_seen",
          "type": "VARCHAR",
          "properties": {
            "displayName": "First Seen",
            "description": "Timestamp when the agent was first discovered or registered"
          }
        },
        {
          "name": "last_seen",
          "type": "DATE",
          "properties": {
            "displayName": "Last Seen",
            "description": "Date when the agent was last active or reported data"
          }
        },
        {
          "name": "nuid",
          "type": "INTEGER",
          "properties": {
            "displayName": "Network UID",
            "description": "Network unique identifier for the agent"
          }
        },
        {
          "name": "dev_id",
          "type": "INTEGER",
          "properties": {
            "displayName": "Device ID",
            "description": "Device identifier where the agent is deployed"
          }
        },
        {
          "name": "is_stale",
          "type": "BOOLEAN",
          "properties": {
            "displayName": "Is Stale",
            "description": "Indicates if the agent data is stale or outdated"
          }
        },
        {
          "name": "raw_created_at",
          "type": "DATE",
          "properties": {
            "displayName": "Raw Created At",
            "description": "Original creation timestamp from source system"
          }
        },
        {
          "name": "store_created_at",
          "type": "DATE",
          "properties": {
            "displayName": "Store Created At",
            "description": "Timestamp when record was created in data store"
          }
        },
        {
          "name": "store_updated_at",
          "type": "DATE",
          "properties": {
            "displayName": "Store Updated At",
            "description": "Timestamp when record was last updated in data store"
          }
        },
        {
          "name": "process_id",
          "type": "VARCHAR",
          "properties": {
            "displayName": "Process ID",
            "description": "Identifier of the data processing pipeline"
          }
        },
        {
          "name": "is_active",
          "type": "BOOLEAN",
          "isCalculated": true,
          "expression": "CASE WHEN last_seen >= CURRENT_DATE - INTERVAL '7 days' THEN true ELSE false END",
          "properties": {
            "displayName": "Is Active",
            "description": "Calculated boolean field that determines if an agent is considered operationally active based on recent communication within the last 7 days. This field is fundamental for security operations monitoring, enabling teams to quickly identify agent health issues, coverage gaps, and potential security blind spots. Used in automated alerting systems, compliance reporting, and executive dashboards showing overall security monitoring effectiveness across the enterprise."
          }
        },
        {
          "name": "days_since_last_seen",
          "type": "INTEGER",
          "isCalculated": true,
          "expression": "DATEDIFF(day, last_seen, CURRENT_DATE)",
          "properties": {
            "displayName": "Days Since Last Seen",
            "description": "Calculated field showing the number of days elapsed since the agent last reported data or sent a heartbeat signal. This metric is critical for prioritizing agent maintenance activities, identifying devices that may be offline or compromised, and measuring the staleness of security monitoring coverage. Values over 7 days typically require investigation, while values over 30 days may indicate permanent device decommissioning or serious technical issues requiring escalation."
          }
        }
      ],
      "primaryKey": "nuid",
      "properties": {
        "displayName": "Security Agents",
        "description": "Monitoring agents deployed for security data collection"
      },
