  ],
  "relationships": [
    {
      "name": "agent_to_asset_relationship",
      "models": [
        "dev_agents",
        "dev_assets"
      ],
      "joinType": "MANY_TO_ONE",
      "condition": "dev_agents.dev_id = dev_assets.dev_id AND dev_agents.nuid = dev_assets.nuid",
      "properties": {
        "displayName": "Agent to Asset Relationship",
        "description": "Relationship between security agents and their monitored assets"
      }
    }
  ],
  "metrics": [
    {
      "name": "agent_health_metrics",
      "baseObject": "security_agents",
      "dimension": [
        {
          "name": "agent",
          "type": "VARCHAR"
        },
        {
          "name": "display_source",
          "type": "VARCHAR"
        }
      ],
      "measure": [
        {
          "name": "total_agents",
          "type": "INTEGER",
          "expression": "COUNT(*)"
        },
        {
          "name": "active_agents",
          "type": "INTEGER",
          "expression": "COUNT(CASE WHEN is_active = true THEN 1 END)"
        },
        {
          "name": "stale_agents",
          "type": "INTEGER",
          "expression": "COUNT(CASE WHEN is_stale = true THEN 1 END)"
        },
        {
          "name": "inactive_agents",
          "type": "INTEGER",
          "expression": "COUNT(CASE WHEN is_active = false THEN 1 END)"
        },
        {
          "name": "agent_uptime_percentage",
          "type": "DECIMAL",
          "expression": "COUNT(CASE WHEN is_active = true THEN 1 END) * 100.0 / COUNT(*)"
        },
        {
          "name": "avg_days_since_last_seen",
          "type": "DECIMAL",
          "expression": "AVG(days_since_last_seen)"
        }
      ],
      "timeGrain": [
        {
          "name": "last_seen_grain",
          "refColumn": "last_seen",
          "dateParts": [
            "YEAR",
            "QUARTER",
            "MONTH",
            "WEEK",
            "DAY"
          ]
        }
      ],
      "properties": {
        "displayName": "Agent Health Metrics",
        "description": "Core health and availability metrics for security agents"
      }
    },
    {
      "name": "agent_source_analytics",
      "baseObject": "security_agents",
      "dimension": [
        {
          "name": "display_source",
          "type": "VARCHAR"
        },
        {
          "name": "agent",
          "type": "VARCHAR"
        }
      ],
      "measure": [
        {
          "name": "agents_by_source",
          "type": "INTEGER",
          "expression": "COUNT(*)"
        },
        {
          "name": "active_agents_by_source",
          "type": "INTEGER",
          "expression": "COUNT(CASE WHEN is_active = true THEN 1 END)"
        },
        {
          "name": "source_reliability_score",
          "type": "DECIMAL",
          "expression": "COUNT(CASE WHEN is_active = true AND is_stale = false THEN 1 END) * 100.0 / COUNT(*)"
        },
        {
          "name": "unique_devices_covered",
          "type": "INTEGER",
          "expression": "COUNT(DISTINCT dev_id)"
        }
      ],
      "properties": {
        "displayName": "Agent Source Analytics",
        "description": "Performance and distribution metrics by agent source"
      }
    }
  ],
  "views": [
    {
      "name": "agent_status_overview",
      "statement": "SELECT agent, display_source, COUNT(*) as agent_count, COUNT(CASE WHEN is_active = true THEN 1 END) as active_count, COUNT(CASE WHEN is_stale = true THEN 1 END) as stale_count FROM security_agents GROUP BY agent, display_source ORDER BY agent_count DESC",
      "properties": {
        "displayName": "Agent Status Overview",
        "description": "High-level overview of agent status by type and source"
      }
    },
    {
      "name": "inactive_agents_alert",
      "statement": "SELECT * FROM security_agents WHERE is_active = false ORDER BY days_since_last_seen DESC",
      "properties": {
        "displayName": "Inactive Agents Alert",
        "description": "List of inactive agents requiring attention"
      }
    },
    {
      "name": "agent_coverage_gaps",
      "statement": "SELECT dev_id, COUNT(DISTINCT agent) as agent_types_deployed FROM security_agents GROUP BY dev_id HAVING COUNT(DISTINCT agent) < 3 ORDER BY agent_types_deployed ASC",
      "properties": {
        "displayName": "Agent Coverage Gaps",
        "description": "Devices with potentially insufficient agent coverage"
      }
    }
  ],
  "enumDefinitions": [
    {
      "name": "AgentStatusEnum",
      "values": [
        {
          "name": "Active",
          "value": "Active"
        },
        {
          "name": "Inactive",
          "value": "Inactive"
        },
        {
          "name": "Stale",
          "value": "Stale"
        }
      ],
      "properties": {
        "displayName": "Agent Status",
        "description": "Possible agent operational status values"
      }
    }
  ]
}