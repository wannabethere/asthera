results in instructions: [{'content': '{"type": "INSTRUCTION", "question": "Which CVEs have the highest GTM risk score above 80 that are still active?", "sql": "SELECT cve_id, gtm_score, severity, state FROM dev_vulnerability_instances WHERE gtm_score > 80 AND state = \'ACTIVE\' ORDER BY gtm_score DESC", "chain_of_thought": "1. Goal: Prioritize vulnerabilities for remediation. 2. Use GTM score to reflect org-specific risk. 3. Filter by GTM > 80 and active state. 4. Return CVE details and sort by highest score.", "is_default": false}', 'metadata': {'chain_of_thought': '1. Goal: Prioritize vulnerabilities for remediation. 2. Use GTM score to reflect org-specific risk. 3. Filter by GTM > 80 and active state. 4. Return CVE details and sort by highest score.', 'id': '58e56af2-85a6-456a-8380-cccdd118c17e', 'instruction': '', 'instruction_id': 'f6e79b19-8894-4edd-88d6-653db46719be', 'is_default': False, 'project_id': 'cve_data', 'sql': "SELECT cve_id, gtm_score, severity, state FROM dev_vulnerability_instances WHERE gtm_score > 80 AND state = 'ACTIVE' ORDER BY gtm_score DESC"}, 'score': 1.0, 'id': '58e56af2-85a6-456a-8380-cccdd118c17e'}, {'content': '{"type": "INSTRUCTION", "question": "What are the top 5 vulnerabilities by total number of affected devices?", "sql": "SELECT cve_id, COUNT(DISTINCT dev_id) AS affected_devices FROM dev_vulnerability_instances GROUP BY cve_id ORDER BY affected_devices DESC LIMIT 5", "chain_of_thought": "1. Goal: Identify high-spread vulnerabilities. 2. Aggregate by CVE ID and count distinct devices. 3. Sort in descending order. 4. Limit to top 5.", "is_default": false}', 'metadata': {'chain_of_thought': '1. Goal: Identify high-spread vulnerabilities. 2. Aggregate by CVE ID and count distinct devices. 3. Sort in descending order. 4. Limit to top 5.', 'id': '2ffcaeea-e291-456b-a8fe-7c240c9144ed', 'instruction': '', 'instruction_id': '14602fcd-b3df-4ddb-a723-f837220f9a9d', 'is_default': False, 'project_id': 'cve_data', 'sql': 'SELECT cve_id, COUNT(DISTINCT dev_id) AS affected_devices FROM dev_vulnerability_instances GROUP BY cve_id ORDER BY affected_devices DESC LIMIT 5'}, 'score': 0.5, 'id': '2ffcaeea-e291-456b-a8fe-7c240c9144ed'}, {'content': '{"type": "INSTRUCTION", "question": "Which devices have the highest number of critical vulnerabilities?", "sql": "SELECT dev_id, COUNT(*) as critical_vulns FROM dev_vulnerability_instances WHERE severity = 4 GROUP BY dev_id ORDER BY critical_vulns DESC", "chain_of_thought": "1. Goal: Spot most vulnerable devices. 2. Severity level 4 = Critical. 3. Count vulnerabilities per device. 4. Sort descending.", "is_default": false}', 'metadata': {'chain_of_thought': '1. Goal: Spot most vulnerable devices. 2. Severity level 4 = Critical. 3. Count vulnerabilities per device. 4. Sort descending.', 'id': 'b0328e07-124b-4d00-b911-a287d82de49f', 'instruction': '', 'instruction_id': '2774d8b3-570c-4938-a292-5b891e25733c', 'is_default': False, 'project_id': 'cve_data', 'sql': 'SELECT dev_id, COUNT(*) as critical_vulns FROM dev_vulnerability_instances WHERE severity = 4 GROUP BY dev_id ORDER BY critical_vulns DESC'}, 'score': 0.3333333333333333, 'id': 'b0328e07-124b-4d00-b911-a287d82de49f'}, {'content': '{"type": "INSTRUCTION", "question": "How many vulnerabilities are patched vs unpatched across the environment?", "sql": "SELECT COUNT(CASE WHEN patches IS NOT NULL THEN 1 END) AS patched, COUNT(CASE WHEN patches IS NULL THEN 1 END) AS unpatched FROM dev_vulnerability_instances", "chain_of_thought": "1. Goal: Assess patch coverage. 2. Use NULL check on \'patches\' field. 3. Conditional count of patched vs unpatched. 4. No GROUP BY needed for global view.", "is_default": false}', 'metadata': {'chain_of_thought': "1. Goal: Assess patch coverage. 2. Use NULL check on 'patches' field. 3. Conditional count of patched vs unpatched. 4. No GROUP BY needed for global view.", 'id': '64dc71f1-fa9c-41be-9a79-9e5cf579db01', 'instruction': '', 'instruction_id': '39a07780-f570-48f3-abbc-97d8dd7d7025', 'is_default': False, 'project_id': 'cve_data', 'sql': 'SELECT COUNT(CASE WHEN patches IS NOT NULL THEN 1 END) AS patched, COUNT(CASE WHEN patches IS NULL THEN 1 END) AS unpatched FROM dev_vulnerability_instances'}, 'score': 0.25, 'id': '64dc71f1-fa9c-41be-9a79-9e5cf579db01'}, {'content': '{"type": "INSTRUCTION", "question": "Which CVEs have no patch available but affect more than 10 devices?", "sql": "SELECT cve_id, COUNT(*) AS affected_instances FROM dev_vulnerability_instances WHERE patches IS NULL GROUP BY cve_id HAVING COUNT(*) > 10 ORDER BY affected_instances DESC", "chain_of_thought": "1. Goal: Identify widespread unpatchable issues. 2. Filter by NULL patches. 3. Group by CVE ID. 4. Only include those with >10 affected devices.", "is_default": false}', 'metadata': {'chain_of_thought': '1. Goal: Identify widespread unpatchable issues. 2. Filter by NULL patches. 3. Group by CVE ID. 4. Only include those with >10 affected devices.', 'id': 'a602dee9-011f-4ce7-833e-006b82a5e28c', 'instruction': '', 'instruction_id': 'de5898d9-718f-424c-9322-a31d376c5215', 'is_default': False, 'project_id': 'cve_data', 'sql': 'SELECT cve_id, COUNT(*) AS affected_instances FROM dev_vulnerability_instances WHERE patches IS NULL GROUP BY cve_id HAVING COUNT(*) > 10 ORDER BY affected_instances DESC'}, 'score': 0.2, 'id': 'a602dee9-011f-4ce7-833e-006b82a5e28c'}]
