2025-12-06 15:16:13,043 - genieml-agents - INFO - sql_pairs_result in retrieval_helper Create a calculated column for bastion_impact that calculates impact score specifically for bastion host devices using impact_class and propagation_class: {'documents': [{'question': 'What is the distribution of vulnerability severity levels across all CVE instances?', 'sql': "SELECT severity_category, COUNT(*) as vulnerability_count, (COUNT(*) * 100.0 / (SELECT COUNT(*) FROM vulnerability_instances)) as percentage FROM vulnerability_instances GROUP BY severity_category ORDER BY CASE severity_category WHEN 'Critical' THEN 1 WHEN 'High' THEN 2 WHEN 'Medium' THEN 3 ELSE 4 END", 'instructions': 'Calculate percentage distribution of vulnerability severity categories to visualize overall security risk landscape and identify priority areas.', 'score': 1.0, 'sql_pair_id': 'e4b05d1c-e3f5-4006-9f51-637710657406', 'project_id': 'cve_data'}, {'question': 'How many critical vulnerabilities are currently active and require immediate attention?', 'sql': 'SELECT COUNT(*) as critical_active_vulnerabilities, COUNT(DISTINCT dev_id) as affected_devices, COUNT(DISTINCT cve_id) as unique_cves FROM vulnerability_instances WHERE is_critical = true AND is_active = true', 'instructions': 'Count critical active vulnerabilities with device and CVE impact to assess immediate security response requirements.', 'score': 0.5, 'sql_pair_id': 'f1b47d53-978b-47b9-b741-552eeb13ab4e', 'project_id': 'cve_data'}, {'question': 'Which devices have the highest number of vulnerabilities and need priority remediation?', 'sql': 'SELECT dev_id, COUNT(*) as total_vulnerabilities, COUNT(CASE WHEN is_critical = true THEN 1 END) as critical_vulnerabilities, COUNT(CASE WHEN is_active = true THEN 1 END) as active_vulnerabilities, AVG(risk_score) as avg_risk_score FROM vulnerability_instances GROUP BY dev_id HAVING COUNT(*) >= 5 ORDER BY critical_vulnerabilities DESC, total_vulnerabilities DESC LIMIT 20', 'instructions': 'Rank devices by vulnerability count and criticality to prioritize remediation efforts and resource allocation.', 'score': 0.3333333333333333, 'sql_pair_id': '77e46283-0893-4790-bce2-3452e7321d7c', 'project_id': 'cve_data'}, {'question': 'What is the average time to detect vulnerabilities after CVE publication?', 'sql': 'SELECT AVG(days_to_detection) as avg_days_to_detection, MIN(days_to_detection) as fastest_detection, MAX(days_to_detection) as slowest_detection, COUNT(CASE WHEN days_to_detection <= 1 THEN 1 END) as same_day_detections FROM vulnerability_instances WHERE days_to_detection IS NOT NULL', 'instructions': 'Calculate detection timeliness metrics to assess vulnerability scanning and intelligence effectiveness.', 'score': 0.25, 'sql_pair_id': 'deb70a6f-d087-4eef-b638-01d9fee76e2d', 'project_id': 'cve_data'}, {'question': 'How many vulnerabilities have been remediated vs still active by severity level?', 'sql': "SELECT severity_category, COUNT(*) as total_vulnerabilities, COUNT(CASE WHEN is_remediated = true THEN 1 END) as remediated_count, COUNT(CASE WHEN is_active = true THEN 1 END) as active_count, (COUNT(CASE WHEN is_remediated = true THEN 1 END) * 100.0 / COUNT(*)) as remediation_rate FROM vulnerability_instances GROUP BY severity_category ORDER BY CASE severity_category WHEN 'Critical' THEN 1 WHEN 'High' THEN 2 WHEN 'Medium' THEN 3 ELSE 4 END", 'instructions': 'Compare remediation status across severity levels to track security program progress and identify bottlenecks.', 'score': 0.2, 'sql_pair_id': 'c973f13c-59ae-427a-bb30-608ad87d0a7b', 'project_id': 'cve_data'}, {'question': 'Which CVEs have the highest risk scores and affect the most devices?', 'sql': 'SELECT cve_id, COUNT(*) as instance_count, COUNT(DISTINCT dev_id) as affected_devices, AVG(risk_score) as avg_risk_score, MAX(published_time) as latest_published FROM vulnerability_instances WHERE is_active = true GROUP BY cve_id ORDER BY avg_risk_score DESC, affected_devices DESC LIMIT 15', 'instructions': 'Rank CVEs by risk score and device impact to prioritize vulnerability response and resource allocation.', 'score': 0.16666666666666666, 'sql_pair_id': '7052b295-8829-4a11-847c-fdb838b50810', 'project_id': 'cve_data'}, {'question': 'What percentage of vulnerabilities have fixes or patches available?', 'sql': 'SELECT COUNT(*) as total_vulnerabilities, COUNT(CASE WHEN has_fix_available = true THEN 1 END) as vulnerabilities_with_fixes, (COUNT(CASE WHEN has_fix_available = true THEN 1 END) * 100.0 / COUNT(*)) as fix_availability_rate FROM vulnerability_instances', 'instructions': 'Calculate patch availability rate to assess remediation feasibility and identify vulnerabilities needing workarounds.', 'score': 0.14285714285714285, 'sql_pair_id': '842248c8-4bc4-4543-bc99-438ce2c399aa', 'project_id': 'cve_data'}, {'question': 'How has the number of new vulnerabilities changed month by month over the past year?', 'sql': "SELECT FORMAT(published_time, 'yyyy-MM') as publication_month, COUNT(DISTINCT cve_id) as new_cves, COUNT(*) as total_instances, AVG(cvss_score) as avg_cvss_score FROM vulnerability_instances WHERE published_time >= DATEADD(month, -12, CURRENT_TIMESTAMP) GROUP BY FORMAT(published_time, 'yyyy-MM') ORDER BY publication_month", 'instructions': 'Track monthly CVE publication trends to understand threat landscape evolution and resource planning needs.', 'score': 0.125, 'sql_pair_id': '0bec4e8a-8c12-4204-a7c5-863b5570f401', 'project_id': 'cve_data'}, {'question': 'Which vulnerabilities are tagged as malware-related and require enhanced monitoring?', 'sql': 'SELECT cve_id, COUNT(*) as instance_count, COUNT(DISTINCT dev_id) as affected_devices, AVG(cvss_score) as avg_cvss_score, AVG(risk_score) as avg_risk_score, MIN(detected_time) as first_detected FROM vulnerability_instances WHERE has_malware_tag = true GROUP BY cve_id ORDER BY avg_risk_score DESC, affected_devices DESC', 'instructions': 'List malware-associated vulnerabilities with impact metrics for enhanced security monitoring and response planning.', 'score': 0.1111111111111111, 'sql_pair_id': '8a848dbe-3c20-4e75-8693-74e82552043c', 'project_id': 'cve_data'}, {'question': 'What is the average time to remediate vulnerabilities by severity level?', 'sql': "SELECT severity_category, AVG(days_to_remediation) as avg_days_to_remediation, COUNT(CASE WHEN days_to_remediation <= 7 THEN 1 END) as fast_remediations, COUNT(CASE WHEN days_to_remediation > 90 THEN 1 END) as slow_remediations FROM vulnerability_instances WHERE days_to_remediation IS NOT NULL GROUP BY severity_category ORDER BY CASE severity_category WHEN 'Critical' THEN 1 WHEN 'High' THEN 2 WHEN 'Medium' THEN 3 ELSE 4 END", 'instructions': 'Calculate remediation timeliness by severity level to assess response effectiveness and identify improvement areas.', 'score': 0.1, 'sql_pair_id': 'daaab041-0a01-4de0-b719-43ea35212a0f', 'project_id': 'cve_data'}]}
