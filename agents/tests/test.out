CREATE TABLE dev_assets (
  nuid INTEGER -- Network unique identifier for the asset,
  dev_id INTEGER -- Device identifier,
  device_type VARCHAR -- Type of device (server, workstation, laptop, etc.),
  roles TEXT -- Comma-separated list of roles assigned to the asset,
  site_name VARCHAR -- Physical site or location name,
  location_id VARCHAR -- Unique identifier for the physical location,
  is_retired BOOLEAN -- Indicates if the asset has been retired,
  is_stale BOOLEAN -- Indicates if the asset data is stale or outdated
);
