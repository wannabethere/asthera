rties': {'displayName': 'Software to Vulnerability Relationship', 'description': 'Relationship between software installations and their vulnerability instances'}}, {'name': 'software_to_cve_relationship', 'models': ['dev_software_instances', 'dev_cve'], 'joinType': 'MANY_TO_MANY', 'condition': 'dev_software_instances.cpe = dev_cve.cpe OR (dev_software_instances.vendor = dev_cve.vendor AND dev_software_instances.product = dev_cve.product AND dev_software_instances.version = dev_cve.version)', 'properties': {'displayName': 'Software to CVE Relationship', 'description': 'Relationship between software installations and CVE assessments via CPE or vendor/product/version matching'}}]}
