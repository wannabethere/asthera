version: 2

models:
  - name: {{ model_name }}
    description: "{{ description }}"
    config:
      tags:
        - gold
        - cube
        - "dashboard_{{ dashboard_id }}"
    columns:
      - name: connection_id
        description: "Multi-tenant isolation key"
        tests:
          - not_null

      - name: tenant_id
        description: "Tenant identifier"
        tests:
          - not_null

      - name: period
        description: "Aggregation period truncated to {{ grain }}"
        tests:
          - not_null
      {%- for dim in dimensions %}

      - name: {{ dim.name }}
        description: "{{ dim.description if dim.description else dim.name | replace('_', ' ') | title }}"
      {%- endfor %}
      {%- for metric in metrics %}

      - name: {{ metric.name }}
        description: "{{ metric.description if metric.description else metric.aggregation + ' of ' + metric.column }}"
        tests:
          - not_null
      {%- endfor %}
