  "agent_mapping": {
    "csod_workflow": {
      "agent_id": "csod-workflow",
      "display_name": "CSOD Metrics & KPIs Workflow",
      "capabilities": ["metrics", "dashboards", "reports", "sql", "use_cases", "alerts", "discovery"]
    },
    "csod_metric_advisor_workflow": {
      "agent_id": "csod-metric-advisor",
      "display_name": "CSOD Metric Advisor",
      "capabilities": ["metrics_recommendations", "insights", "causal_analysis"]
    }
  },
  "default_agent": "csod_workflow",
  "multi_skill_routing": {
    "strategy": "primary_skill",
    "fallback": "csod_workflow"
  },
  "categories": {
    "data_intelligence": {
      "label": "Data Intelligence",
      "description": "Foundational data understanding — underlies all four analytical modes"
    }
  },
  "scoping_filters": {
    "data_source": { "label": "Data Source", "type": "multiselect", "options": ["cornerstone.lms", "workday.hcm", "cornerstone.training", "all_configured"] },
    "discovery_scope": { "label": "Discovery Scope", "type": "select", "options": ["all_tables", "silver_gold_only", "focus_domain_tables", "metrics_only"] },
    "lineage_subject": { "label": "Lineage Subject", "type": "text", "description": "Name of metric, KPI, or table to trace" },
    "lineage_direction": { "label": "Lineage Direction", "type": "select", "options": ["upstream", "downstream", "both"] },
    "table_scope": { "label": "Table Scope", "type": "multiselect", "options": ["all", "bronze_only", "silver_only", "gold_only", "specific_table"] },
    "quality_dimension": { "label": "Quality Check", "type": "multiselect", "options": ["completeness", "freshness", "consistency", "accuracy", "all"] },
    "analysis_goal": { "label": "Analysis Goal", "type": "text", "description": "Describe the analysis you want to run so the planner can design the right pipeline" },
    "refresh_frequency": { "label": "Refresh Frequency", "type": "select", "options": ["real_time", "hourly", "daily", "weekly", "monthly", "on_demand"] }
  }
