      "agents": ["csod_workflow"],
      "scoping_filters": [],
      "needs_area_matching": false,
      "icon": "terminal"
    },
    "data_discovery": {
      "display_name": "Data Discovery",
      "description": "Explore available schemas, tables, and data assets to understand what analysis is possible from your configured data sources",
      "category": "data_intelligence",
      "intent": "data_discovery",
      "agents": ["csod_workflow"],
      "scoping_filters": ["data_source", "focus_domain", "discovery_scope"],
      "needs_area_matching": false,
      "icon": "search",
      "output_artifacts": ["schema_catalog", "available_metrics_list", "data_capability_assessment", "coverage_gaps"]
    },
    "data_lineage": {
      "display_name": "Data Lineage",
