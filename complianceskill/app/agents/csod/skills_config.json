      "category": "data_intelligence",
      "intent": "data_lineage",
      "agents": ["csod_workflow", "csod_metric_advisor_workflow"],
      "scoping_filters": ["lineage_subject", "lineage_direction", "focus_domain"],
      "needs_area_matching": false,
      "icon": "git-fork",
      "output_artifacts": ["lineage_graph", "column_level_lineage", "transformation_steps", "impact_analysis"]
    },
    "data_quality_analysis": {
      "display_name": "Data Quality Analysis",
