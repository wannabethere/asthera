    "compliance_gap_close": {
      "description": "Audit- or deadline-bounded compliance gap with remediation narrative.",
      "examples": [
        {
          "example_id": "compliance_gap_close_001",
          "user_question": "We have a SOC2 audit in 30 days. Our security compliance training rate is at 71%. We need to get to 90%. What's the gap and how do we close it?",
          "stage_1_intent": {
            "intent": "compliance_gap_close",
            "confidence": 0.97,
            "quadrant": "Diagnostic",
            "routing": "full_spine",
            "spine_steps_skipped": [],
            "tags": [
              "soc2",
              "gap_analysis",
              "deadline_bounded",
              "compliance_training"
            ],
            "signals": [
              {
                "key": "terminal_metric",
                "value": "compliance_rate — current 71%, target 90%, gap 19pts immediately computable"
              },
              {
                "key": "urgency",
                "value": "30-day hard deadline — lag structure analysis required before any recommendation"
              },
              {
                "key": "analysis_type",
                "value": "Gap Analysis with forward projection — intervention ordering is critical"
              },
              {
                "key": "compliance_context",
                "value": "SOC2 audit — audit posture (trajectory + evidence) matters as much as raw rate"
              },
              {
                "key": "implicit",
                "value": "Is this fixable in 30 days? Answer requires causal lag structure, not just current rate"
              }
            ],
            "implicit_questions": [
              "Can we realistically close 19 points in 30 days?",
              "Is the shortfall caused by disengagement or assignment overload?",
              "Which departments should we prioritize?",
              "What is a defensible audit posture if we can't hit 90%?"
