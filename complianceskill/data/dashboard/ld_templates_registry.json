      "id": "training-plan-tracker",
      "name": "Training Plan Tracker",
      "icon": "📋",
      "category": "ld_training",
      "description": "Training plan execution view. Top KPI cards (Goals, Activities, Employees, Completions) + status breakdown bar chart + completion donut + full assign-details table with per-employee status tracking. Optimized for training admins managing plan rollouts.",
      "primitives": ["topbar", "kpi_cards_row", "chart_row", "detail_table"],
      "panels": {
        "top_kpis": "goals_count + activities_count + employees_count + completions_count",
        "charts_row": "status_bar_chart + direct_assigns_kpi + completion_donut",
        "bottom": "assign_details_table"
      },
      "layout_grid": {
        "row1": {"type": "kpi_cards", "columns": 4, "height": "120px"},
        "row2": {"type": "charts", "columns": "1fr 200px 250px", "height": "200px"},
        "row3": {"type": "data_table", "columns": 1, "height": "flex"}
