ichaelrhodes/draw-svg-path#2.0.1\n```\n\n## use\n``` js\nvar draw = require('draw-svg-path')\nvar parse = require('parse-svg-path')\n\nvar canvas = document.createElement('canvas')\nvar ctx = canvas.getContext('2d')\n\nctx.beginPath()\nctx.lineWidth = 1\nctx.strokeStyle = '#000000'\nctx.fillStyle = 'transparent'\n\n// Accepts /^(un)?parsed$/ paths\ndraw(ctx, parse('M20 20 L25 25'))\ndraw(ctx, 'M10 10 L15 15')\n\nctx.stroke()\nctx.closePath()\n\ndocument.body.appendChild(canvas)\n```\n\n## obey\n[MIT](http://opensource.org/licenses/MIT)\n","maintainers":[{"name":"michaelrhodes","email":"spam@michaelrhod.es"}],"time":{"modified":"2022-06-15T23:56:00.119Z","created":"2014-04-29T04:27:18.929Z","1.0.0":"2014-04-29T04:27:18.929Z","2.0.0":"2018-01-26T01:35:55.864Z","2.0.1":"2018-01-26T06:39:34.288Z"},"homepage":"https://github.com/michaelrhodes/draw-svg-path#readme","keywords":["svg","path","canvas"],"author":{"name":"Michael Rhodes"},"license":"MIT","readmeFilename":"readme.md","repository":{"type":"git","url":"git://github.com/michaelrhodes/draw-svg-path.git"},"bugs":{"url":"https://github.com/michaelrhodes/draw-svg-path/issues"}}