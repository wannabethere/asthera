minX, minY, minZ, maxX, maxY, maxZ] = bounds([x1, y1, z1, x2, y2, z2, ...], 3)\r\n```\r\n","maintainers":[{"name":"dfcreative","email":"df.creative@gmail.com"}],"time":{"modified":"2022-06-13T03:28:01.660Z","created":"2017-06-01T00:11:23.870Z","1.0.0":"2017-06-01T00:11:23.870Z","1.0.1":"2017-06-08T17:39:18.516Z"},"homepage":"https://github.com/dfcreative/array-bounds#readme","keywords":["array","bounds","limits","array min","min","max","statistics","samples"],"repository":{"type":"git","url":"git+https://github.com/dfcreative/array-bounds.git"},"author":{"name":"Dima Yv","email":"dfcreative@gmail.com"},"bugs":{"url":"https://github.com/dfcreative/array-bounds/issues"},"license":"MIT","readmeFilename":"readme.md"}