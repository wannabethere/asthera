# Copy to .env in knowledge/ and set values. Do not check in .env.

# -----------------------------------------------------------------------------
# LLM / API keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# LLM defaults (per-type models in config/llm_models.yaml)
# -----------------------------------------------------------------------------
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.0
LLM_PROVIDER=openai

# -----------------------------------------------------------------------------
# Vector store (chroma | qdrant | pinecone)
# -----------------------------------------------------------------------------
VECTOR_STORE_TYPE=qdrant
VECTOR_STORE_PATH=../../data/vector_store
CHROMA_STORE_PATH=../../data/chroma_db
CHROMA_USE_LOCAL=true
CHROMA_HOST=
CHROMA_PORT=8888
CHROMA_COLLECTION_NAME=default
# CHROMA_PERSIST_DIRECTORY=  # optional; defaults to CHROMA_STORE_PATH

QDRANT_HOST=
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=default
# Path to sql_meta dir for project_reader_qdrant (indexing). Use absolute path to avoid resolution issues.
# Example: SQL_META_PATH=/Users/you/flowharmonicai/data/sql_meta
SQL_META_PATH=../../data/sql_meta

PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=default

# -----------------------------------------------------------------------------
# Cache (memory | redis)
# -----------------------------------------------------------------------------
CACHE_TYPE=memory
CACHE_TTL=120
CACHE_MAXSIZE=1000000

REDIS_HOST=
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SSL=false

# -----------------------------------------------------------------------------
# Database (postgres | mysql)
# -----------------------------------------------------------------------------
DATABASE_TYPE=postgres
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_POOL_MIN_SIZE=5
POSTGRES_POOL_MAX_SIZE=20
POSTGRES_SSL_MODE=require

MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_DB=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_POOL_MIN_SIZE=5
MYSQL_POOL_MAX_SIZE=20

# -----------------------------------------------------------------------------
# Embedding
# -----------------------------------------------------------------------------
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# API security (token required for /api/* when enabled)
# -----------------------------------------------------------------------------
API_SECURITY_ENABLED=false
# List of provisioned tokens (comma-separated and/or newline). Generate with:
#   from app.core.security import encode_oauth_token
#   encode_oauth_token("org", "team", 1735689600, 2*365*24*3600)
API_PROVISIONED_TOKENS=eyJvcmciOiJkZWZhdWx0IiwidGVhbSI6InBsYXRmb3JtIiwiaWF0IjoxNzM1Njg5NjAwLCJ2YWxpZF9zZWMiOjYzMDcyMDAwfQ,eyJvcmciOiJkZWZhdWx0IiwidGVhbSI6ImludGVncmF0aW9ucyIsImlhdCI6MTczNTY4OTYwMCwidmFsaWRfc2VjIjo2MzA3MjAwMH0,eyJvcmciOiJrbm93bGVkZ2UiLCJ0ZWFtIjoiYXBpLWNsaWVudHMiLCJpYXQiOjE3MzU2ODk2MDAsInZhbGlkX3NlYyI6NjMwNzIwMDB9
# Optional: path to file with one token per line (merged with list above). Path relative to repo root.
# API_PROVISIONED_TOKENS_FILE=config/provisioned_tokens.txt
