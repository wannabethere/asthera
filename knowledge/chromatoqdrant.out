CREATE TABLE personorganization_sumtotal (
  personfk BIGINT -- Person Foreign Key -- Foreign key referencing the person entity in the database.,
  organizationfk BIGINT -- Organization Foreign Key -- Foreign key referencing the organization table to get organization details.,
  isprimary BIGINT -- Is Primary -- Indicates whether the organization is the primary one associated with the person.,
  joiningdate TIMESTAMP -- Joining Date -- The date when a person joined the organization.,
  createdby TEXT -- Created By -- Identifier for the user or system that created the record.,
  mainorganization BIGINT -- Main Organization -- Column representing the main organization associated with a person.,
  synchfaultflg BIGINT -- Synchronization Fault Flag -- Indicates whether there is a synchronization fault for the associated person and organization.,
  synchfaultcntlstary TEXT -- Synchronization Fault Count List Array -- A text field that stores a list of synchronization fault counts related to person-organization records.,
  mvpbatchid BIGINT -- MVP Batch ID -- Identifier for the batch process related to the person organization records.,
  deleted BIGINT -- Deleted Flag -- Indicates whether the record has been marked as deleted.,
  createddate TIMESTAMP -- Created Date -- Timestamp indicating when the record was created in the system.,
  modifieddate TIMESTAMP -- Modified Date -- Timestamp indicating when the record was last modified.,
  modifiedby TEXT -- Modified By -- Column indicating the user who last modified the record.
);
