2026-02-04 21:35:11,598 - app.indexing.ddl_utils - INFO - Generated DDL for dev_network_devices: -- Network device inventory and management system tracking IP addresses, MAC addresses, manufacturers, and device lifecycle information across different network sites and subnets
CREATE TABLE dev_network_devices (
  id BIGINT NOT NULL -- Device ID -- Unique identifier for the network device record,
  ip VARCHAR -- IP Address -- IPv4 address assigned to the network device,
  subnet VARCHAR -- Subnet -- Network subnet in CIDR notation (e.g., 192.168.1.0/24) that the device belongs to,
  site VARCHAR -- Site Location -- Physical site or location identifier where the device is deployed (Unknown if not specified),
  mac VARCHAR -- MAC Address -- Media Access Control (MAC) address - unique hardware identifier for the network interface,
  manufacturer VARCHAR -- Manufacturer -- Device manufacturer name (e.g., Microsoft Corporation, VMware Inc., AWS) based on MAC address OUI lookup,
  updated_at TIMESTAMP -- Last Updated -- Timestamp when the device record was last updated or seen on the network,
  nuid INTEGER -- Network Unit ID -- Network unit identifier for grouping or organizational purposes,
  dev_id INTEGER -- Device Internal ID -- Internal device identifier used by the network management system,
  is_stale BOOLEAN NOT NULL -- Is Stale -- Boolean flag indicating if the device record is considered stale or outdated (not recently seen),
  raw_created_at TIMESTAMP -- Raw Creation Time -- Original timestamp when the device was first detected or created in the raw data collection system,
  store_created_at TIMESTAMP -- Store Creation Time -- Timestamp when the device record was first stored in the data warehouse,
  store_updated_at TIMESTAMP -- Store Updated Time -- Timestamp when the device record was last updated in the data warehouse,
  process_id VARCHAR -- Process ID -- UUID of the data processing job or batch that processed this device record,
  is_cloud_device BOOLEAN -- Is Cloud Device -- Calculated field indicating if device appears to be cloud-based (AWS, Azure, or private IP ranges),
  is_virtual_machine BOOLEAN -- Is Virtual Machine -- Calculated field indicating if device is likely a virtual machine based on manufacturer,
  subnet_class VARCHAR -- Subnet Class -- Classification of the subnet type (Private Class A/B/C, Public, Loopback, etc.),
  days_since_last_seen INTEGER -- Days Since Last Seen -- Number of days since the device was last updated or seen on the network,
  device_age_category VARCHAR -- Device Age Category -- Categorical age of device based on last seen date,
  ip_octets VARCHAR -- IP Network Segment -- Masked IP address showing network segment (first two octets) for privacy and grouping
);
