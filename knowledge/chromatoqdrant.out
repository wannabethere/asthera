2026-02-04 21:34:56,758 - app.indexing.ddl_utils - INFO - Generated DDL for workday_employee_skills_development: -- Workday employee skills and competency development tracking linked to training activities. This table provides deeper insights into skill acquisition, proficiency levels, and career development impact...
CREATE TABLE workday_employee_skills_development (
  id INTEGER -- ID -- Primary key identifier for the skills development record,
  employee_id VARCHAR -- Employee ID -- Employee identifier matching CSOD user_id for cross-reference,
  employee_name VARCHAR -- Employee Name -- Full name of the employee,
  manager_id VARCHAR -- Manager ID -- Manager's employee ID,
  manager_name VARCHAR -- Manager Name -- Name of the employee's direct manager,
  division VARCHAR -- Division -- Business division matching CSOD division for alignment,
  job_title VARCHAR -- Job Title -- Current job title of the employee,
  job_level VARCHAR -- Job Level -- Career level (e.g., Individual Contributor, Senior, Lead, Manager),
  hire_date DATE -- Hire Date -- Employee's hire date for tenure analysis,
  skill_name VARCHAR -- Skill Name -- Name of the specific skill being developed,
  skill_category VARCHAR -- Skill Category -- Category of skill (Technical, Leadership, Compliance, Soft Skills),
  competency_framework VARCHAR -- Competency Framework -- Competency framework this skill belongs to,
  pre_training_proficiency INTEGER -- Pre-Training Proficiency -- Skill proficiency level before training (1-5 scale),
  post_training_proficiency INTEGER -- Post-Training Proficiency -- Skill proficiency level after training completion (1-5 scale),
  target_proficiency INTEGER -- Target Proficiency -- Target proficiency level for the role (1-5 scale),
  skill_criticality VARCHAR -- Skill Criticality -- Criticality of skill for role (Critical, Important, Beneficial),
  training_curriculum_id VARCHAR -- Training Curriculum ID -- ID linking to CSOD curriculum that developed this skill,
  training_curriculum_title TEXT -- Training Curriculum Title -- Title of training curriculum from CSOD,
  skill_assessment_date DATE -- Skill Assessment Date -- Date when skill proficiency was assessed,
  assessment_method VARCHAR -- Assessment Method -- Method used to assess skill (Self-Assessment, Manager Review, Certification, Practical Test),
  certification_earned VARCHAR -- Certification Earned -- Certification or credential earned through training,
  certification_expiry_date DATE -- Certification Expiry Date -- Date when certification expires,
  cost_center VARCHAR -- Cost Center -- Cost center for training expense allocation,
  training_cost DECIMAL -- Training Cost -- Cost associated with the training program,
  performance_rating DECIMAL -- Performance Rating -- Latest performance rating (1-5 scale),
  career_development_plan VARCHAR -- Career Development Plan -- Associated career development plan,
  succession_plan_role VARCHAR -- Succession Plan Role -- Role in succession planning this skill supports,
  created_at TIMESTAMP -- Created At -- Timestamp when the record was created,
  updated_at TIMESTAMP -- Updated At -- Timestamp when the record was last updated,
  proficiency_improvement INTEGER -- Proficiency Improvement -- Improvement in proficiency level after training,
  target_gap INTEGER -- Target Gap -- Gap remaining to reach target proficiency,
  is_skill_proficient BOOLEAN -- Is Skill Proficient -- Whether employee has reached target proficiency,
  certification_status VARCHAR -- Certification Status -- Current status of certification,
  tenure_months INTEGER -- Tenure Months -- Employee tenure in months,
  roi_indicator DECIMAL -- ROI Indicator -- Simple ROI indicator (proficiency improvement per $1000 spent)
);
