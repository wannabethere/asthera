CREATE TABLE ComplianceRisk_Division (
  divisionRiskId string NOT NULL -- Divisionriskid -- Unique identifier for division-level aggregated risk record.,
  assessmentDate date NOT NULL -- Assessmentdate -- Date of the division-level risk assessment.,
  division string NOT NULL -- Division -- Organizational division or business unit.,
  divisionHeadcount bigint NOT NULL -- Divisionheadcount -- Total number of active employees in the division.,
  totalAssignments bigint NOT NULL -- Totalassignments -- Total compliance training assignments in the division.,
  avgRiskScore double NOT NULL -- Avgriskscore -- Average composite risk score for the division.,
  medianRiskScore double NOT NULL -- Medianriskscore -- Median composite risk score, less sensitive to outliers.,
  riskScorePercentile double NOT NULL -- Riskscorepercentile -- Division's risk score percentile rank among all divisions (0-100).,
  criticalCount bigint NOT NULL -- Criticalcount -- Number of critical risk assignments in the division.,
  highCount bigint NOT NULL -- Highcount -- Number of high risk assignments in the division.,
  moderateCount bigint NOT NULL -- Moderatecount -- Number of moderate risk assignments in the division.,
  lowCount bigint NOT NULL -- Lowcount -- Number of low risk assignments in the division.,
  overdueCount bigint NOT NULL -- Overduecount -- Number of overdue assignments in the division.,
  completionRate double NOT NULL -- Completionrate -- Percentage of completed compliance assignments in the division.,
  avgDaysToComplete double -- Avgdaystocomplete -- Average time to complete training in the division (days).,
  divisionRank bigint NOT NULL -- Divisionrank -- Rank of division by avgRiskScore (1 = lowest risk/best).,
  escalationRequiredCount bigint NOT NULL -- Escalationrequiredcount -- Number of assignments requiring manager escalation in division.,
  riskPerEmployee double NOT NULL -- Riskperemployee -- Average risk score normalized by headcount.,
  complianceHealthScore double NOT NULL -- Compliancehealthscore -- Composite health score for the division (0-100).,
  divisionTrend string -- Divisiontrend -- Risk trend direction for the division (7-day comparison).,
  managerCount bigint NOT NULL -- Managercount -- Number of unique managers in the division.,
  topRiskManager string -- Topriskmanager -- Manager with highest average team risk score in division.,
  bestPracticeFlag string NOT NULL -- Bestpracticeflag -- Indicates if division is a best practice performer.,
  interventionPriority string NOT NULL -- Interventionpriority -- Priority level for compliance intervention resources.
);
