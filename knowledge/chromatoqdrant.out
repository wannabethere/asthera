CREATE TABLE personrelation_sumtotal (
  personfk BIGINT -- Person Foreign Key -- Foreign key reference to a person in the database, linking to the person entity.,
  manager1fk BIGINT -- Manager 1 Foreign Key -- This column establishes the employee's direct reporting line by linking to the record of their primary manager. As a self-referencing foreign key, it contains the identifier of another person within this same person_sumtotal table.,
  manager2fk BIGINT -- Manager 2 Foreign Key -- Foreign key reference to the second manager in the person relation hierarchy.,
  manager3fk BIGINT -- Manager 3 Foreign Key -- Foreign key referencing the third-level manager in the person relation hierarchy.,
  manager4fk BIGINT -- Manager 4 Foreign Key -- Foreign key reference to the fourth manager in the person relation hierarchy.,
  manager5fk BIGINT -- Manager 5 Foreign Key -- Foreign key reference to the fifth-level manager in the person relation hierarchy.,
  manager6fk BIGINT -- Manager 6 Foreign Key -- Foreign key reference to the sixth level manager in the person relation hierarchy.,
  manager7fk BIGINT -- Manager 7 Foreign Key -- Foreign key reference to the manager associated with a person in the personrelation_sumtotal table.,
  manager8fk BIGINT -- Manager 8 Foreign Key -- Foreign key reference to the eighth manager in the person relation table.,
  manager9fk BIGINT -- Manager 9 Foreign Key -- Foreign key reference to the ninth manager in the person relation hierarchy.,
  createddate_ts TIMESTAMP -- Created Date -- Timestamp indicating when the record was created, stored as a string.
);
