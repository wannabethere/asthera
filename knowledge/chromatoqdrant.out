2026-02-04 21:35:09,417 - app.indexing.ddl_utils - INFO - Generated DDL for dev_agents: -- Security monitoring agents deployed across the infrastructure for data collection and monitoring
CREATE TABLE dev_agents (
  agent VARCHAR -- Agent -- Name or identifier of the security monitoring agent,
  display_source VARCHAR -- Display Source -- Human-readable source name for the agent,
  ref_source_id FLOAT -- Reference Source ID -- Reference identifier linking to the source system,
  first_seen VARCHAR -- First Seen -- Timestamp when the agent was first discovered or registered,
  last_seen DATE -- Last Seen -- Date when the agent was last active or reported data,
  nuid INTEGER -- Network UID -- Network unique identifier for the agent,
  dev_id INTEGER -- Device ID -- Device identifier where the agent is deployed,
  is_stale BOOLEAN -- Is Stale -- Indicates if the agent data is stale or outdated,
  raw_created_at DATE -- Raw Created At -- Original creation timestamp from source system,
  store_created_at DATE -- Store Created At -- Timestamp when record was created in data store,
  store_updated_at DATE -- Store Updated At -- Timestamp when record was last updated in data store,
  process_id VARCHAR -- Process ID -- Identifier of the data processing pipeline,
  is_active BOOLEAN -- Is Active -- Calculated boolean field that determines if an agent is considered operationally active based on recent communication within the last 7 days. This field is fundamental for security operations monitoring, enabling teams to quickly identify agent health issues, coverage gaps, and potential security blind spots. Used in automated alerting systems, compliance reporting, and executive dashboards showing overall security monitoring effectiveness across the enterprise.,
  days_since_last_seen INTEGER -- Days Since Last Seen -- Calculated field showing the number of days elapsed since the agent last reported data or sent a heartbeat signal. This metric is critical for prioritizing agent maintenance activities, identifying devices that may be offline or compromised, and measuring the staleness of security monitoring coverage. Values over 7 days typically require investigation, while values over 30 days may indicate permanent device decommissioning or serious technical issues requiring escalation.
);
