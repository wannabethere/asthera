CREATE TABLE User_csod (
  userId string -- Userid -- Unique identifier for users in the Cornerstone system.,
  userName string -- Username -- Column representing the username of the user in the system.,
  fullName string -- Fullname -- The complete name of the user as recorded in the system.,
  email string -- Email -- Column representing the email address of the user.,
  managerId string -- Managerid -- Identifier for the manager of the user, represented as a string.,
