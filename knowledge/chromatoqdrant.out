2026-02-04 21:34:47,441 - app.indexing.ddl_utils - INFO - Generated DDL for ComplianceRisk_Daily: -- TIME SERIES Gold layer table containing daily aggregated compliance risk metrics providing enterprise-wide visibility into organizational compliance health and trends. Sample data includes 50 daily re...
CREATE TABLE ComplianceRisk_Daily (
  dailyRiskId string NOT NULL -- Dailyriskid -- Unique identifier for daily aggregated risk record.,
  assessmentDate date NOT NULL -- Assessmentdate -- Date of the aggregated risk assessment.,
  totalUsers bigint NOT NULL -- Totalusers -- Total number of active users with compliance training assignments.,
  totalAssignments bigint NOT NULL -- Totalassignments -- Total number of compliance training assignments.,
  avgRiskScore double NOT NULL -- Avgriskscore -- Average composite risk score across all user-training combinations.,
  medianRiskScore double NOT NULL -- Medianriskscore -- Median composite risk score, less sensitive to outliers than average.,
  maxRiskScore double NOT NULL -- Maxriskscore -- Highest risk score recorded for the day.,
  criticalCount bigint NOT NULL -- Criticalcount -- Number of assignments with Critical risk category (75-100).,
  highCount bigint NOT NULL -- Highcount -- Number of assignments with High risk category (50-75).,
  moderateCount bigint NOT NULL -- Moderatecount -- Number of assignments with Moderate risk category (25-50).,
  lowCount bigint NOT NULL -- Lowcount -- Number of assignments with Low risk category (0-25).,
  avgImpactScore double NOT NULL -- Avgimpactscore -- Average severity of consequences across all assignments.,
  avgLikelihoodScore double NOT NULL -- Avglikelihoodscore -- Average probability of non-completion across all assignments.,
  overdueCount bigint NOT NULL -- Overduecount -- Number of assignments currently overdue.,
  dueSoon7Days bigint NOT NULL -- Duesoon7Days -- Number of assignments due within the next 7 days.,
  dueSoon14Days bigint NOT NULL -- Duesoon14Days -- Number of assignments due within the next 14 days.,
  dueSoon30Days bigint NOT NULL -- Duesoon30Days -- Number of assignments due within the next 30 days.,
  escalationRequiredCount bigint NOT NULL -- Escalationrequiredcount -- Number of assignments requiring manager escalation.,
  completionRate double NOT NULL -- Completionrate -- Percentage of completed compliance assignments (0-100).,
  avgDaysToComplete double -- Avgdaystocomplete -- Average time taken to complete assignments (in days).,
  riskTrendDirection string -- Risktrenddirection -- Overall risk trend compared to previous day.,
  riskTrendPercentChange double -- Risktrendpercentchange -- Percentage change in average risk score from previous day.
);
