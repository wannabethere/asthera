CREATE TABLE Activity_csod (
  loID string -- Loid -- Identifier for learning objects in the Activity_csod table,
  activityName string -- Activityname -- Name of the activity associated with learning or compliance.,
  activityCode string -- Activitycode -- A code representing a specific activity within the Cornerstone Learn system.,
  isCompliance string -- Iscompliance -- Indicates whether the activity is related to compliance requirements.,
  activityType string -- Activitytype -- Type of activity associated with learning events in the system.,
  estimatedDuration bigint -- Estimatedduration -- Estimated duration of the activity in hours or minutes.,
  isCertification bigint -- Iscertification -- Indicates whether the activity is a certification program.,
  isActive bigint -- Isactive -- Indicates whether the activity is currently active or not.,
  owner string -- Owner -- Column representing the individual or entity responsible for the activity.,
  cost bigint -- Cost -- Represents the cost associated with an activity in the Cornerstone Learn platform.,
  currency string -- Currency -- Column representing the currency type used for cost-related activities.,
  subject string -- Subject -- Column representing the subject of the activity in the CSOD system.,
  provider string -- Provider -- The entity or organization that offers the activity or course.,
  instructor string -- Instructor -- Name of the instructor responsible for the activity.,
  facility string -- Facility -- Column representing the facility where the activity takes place.,
  eventCode string -- Eventcode -- A code representing a specific event in the Activity table.,
  activityStartDate timestamp -- Activitystartdate -- The date when the activity is scheduled to start, represented as a string in timestamp format without time zone.,
  activityEndDate timestamp -- Activityenddate -- The date when the activity concludes, represented as a timestamp without time zone.
);
