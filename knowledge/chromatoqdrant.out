2026-02-04 21:34:43,900 - app.indexing.ddl_utils - INFO - Generated DDL for AttritionRisk_Daily: -- Gold layer table containing daily aggregated attrition risk metrics providing enterprise-wide visibility into talent retention health.
CREATE TABLE AttritionRisk_Daily (
  dailyAttritionRiskId string NOT NULL -- Dailyattritionriskid -- Unique identifier for daily aggregated attrition risk record.,
  assessmentDate date NOT NULL -- Assessmentdate -- Date of the aggregated attrition risk assessment.,
  totalEmployees bigint NOT NULL -- Totalemployees -- Total number of active employees assessed for attrition risk.,
  avgAttritionRiskScore double NOT NULL -- Avgattritionriskscore -- Average composite attrition risk score across all employees.,
  medianAttritionRiskScore double NOT NULL -- Medianattritionriskscore -- Median composite attrition risk score, less sensitive to outliers.,
  criticalFlightRiskCount bigint NOT NULL -- Criticalflightriskcount -- Number of employees with critical attrition risk (75-100).,
  highFlightRiskCount bigint NOT NULL -- Highflightriskcount -- Number of employees with high attrition risk (50-75).,
  moderateFlightRiskCount bigint NOT NULL -- Moderateflightriskcount -- Number of employees with moderate attrition risk (25-50).,
  lowFlightRiskCount bigint NOT NULL -- Lowflightriskcount -- Number of employees with low attrition risk (0-25).,
  avgAttritionImpact double NOT NULL -- Avgattritionimpact -- Average organizational impact if employees depart.,
  avgAttritionLikelihood double NOT NULL -- Avgattritionlikelihood -- Average probability of employee departures.,
  hrEscalationCount bigint NOT NULL -- Hrescalationcount -- Number of employees requiring HR retention intervention.,
  managersAtRisk bigint NOT NULL -- Managersatrisk -- Number of people managers at high/critical flight risk.,
  avgTenureMonths double NOT NULL -- Avgtenuremonths -- Average employee tenure across organization.,
  newHireAtRiskCount bigint NOT NULL -- Newhireatriskcount -- Number of employees in 0-6 month tenure band at high/critical risk.,
  riskTrendDirection string -- Risktrenddirection -- Overall attrition risk trend compared to previous day.,
  riskTrendPercentChange double -- Risktrendpercentchange -- Percentage change in average attrition risk from previous day.
);
