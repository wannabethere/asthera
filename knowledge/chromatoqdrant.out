CREATE TABLE dev_assets (
  nuid INTEGER NOT NULL -- Network UID -- Network unique identifier for the asset,
  dev_id INTEGER NOT NULL -- Device ID -- Device identifier,
  ip VARCHAR -- IP Address -- Network IP address of the asset,
  mac VARCHAR -- MAC Address -- Media Access Control address,
  host_name VARCHAR -- Host Name -- Network hostname of the asset,
  os_arch VARCHAR -- OS Architecture -- Operating system architecture (x86, x64, ARM, etc.),
  os_name VARCHAR -- OS Name -- Operating system name and version,
  os_version VARCHAR -- OS Version -- Operating system version number,
  cpu_model_name VARCHAR -- CPU Model -- Central processing unit model name,
  count_cpu_cores FLOAT -- CPU Cores -- Number of CPU cores,
  total_physical_mem_mb FLOAT -- Total Memory (MB) -- Total physical memory in megabytes,
  uptime_mins FLOAT -- Uptime (Minutes) -- System uptime in minutes,
  secure_boot_status VARCHAR -- Secure Boot Status -- Status of secure boot configuration on the system,
  system_model VARCHAR -- System Model -- System model information,
  power_shell_exec_policy VARCHAR -- PowerShell Execution Policy -- PowerShell execution policy setting,
  smb1 BOOLEAN -- SMB Version 1 -- SMB version 1 protocol status,
  smb2 BOOLEAN -- SMB Version 2 -- SMB version 2 protocol status,
  smb3 BOOLEAN -- SMB Version 3 -- SMB version 3 protocol status,
  domain_joined VARCHAR -- Domain Joined -- Domain membership status,
  smbios_version VARCHAR -- SMBIOS Version -- SMBIOS version information,
  bios_version VARCHAR -- BIOS Version -- BIOS version installed on the system,
  bios_vendor VARCHAR -- BIOS Vendor -- BIOS vendor information,
  bios_release_date TIMESTAMP -- BIOS Release Date -- Date when the BIOS was released,
  serial_number VARCHAR -- Serial Number -- Hardware serial number,
  manufacturer VARCHAR -- Manufacturer -- Hardware manufacturer,
  board_manufacturer VARCHAR -- Board Manufacturer -- Motherboard manufacturer information,
  system_manufacturer VARCHAR -- System Manufacturer -- System manufacturer information,
  is_reboot_pending BOOLEAN -- Reboot Pending -- Indicates if a system reboot is pending,
  is_cloud_asset BOOLEAN -- Cloud Asset -- Indicates if this is a cloud-based asset,
  device_type VARCHAR -- Device Type -- Type of device (server, workstation, laptop, etc.),
  device_subtype VARCHAR -- Device Subtype -- Subtype classification of the device,
  platform VARCHAR -- Platform -- Operating system platform,
  is_manual_canonical_label BOOLEAN -- Manual Canonical Label -- Indicates if the canonical label was manually assigned,
  roles TEXT -- Roles -- Comma-separated list of roles assigned to the asset,
  search_tags TEXT -- Search Tags -- Tags used for searching and filtering assets,
  site_name VARCHAR -- Site Name -- Physical site or location name,
  final_name VARCHAR -- Final Name -- Final canonical name assigned to the asset,
  device_zone VARCHAR -- Device Zone -- Network zone or segment where the device is located,
  location_id VARCHAR -- Location ID -- Unique identifier for the physical location,
  location_region VARCHAR -- Location Region -- Geographic region of the asset,
  location_country VARCHAR -- Location Country -- Country where the asset is located,
  location_city VARCHAR -- Location City -- City where the asset is located,
  location_state VARCHAR -- Location State -- State or province where the asset is located,
  is_bastion_device BOOLEAN -- Bastion Device -- Indicates if this is a bastion host device,
  asset_tags TEXT -- Asset Tags -- Comma-separated list of asset tags for categorization,
  discoverable_tags TEXT -- Discoverable Tags -- Tags that can be discovered automatically,
  inserted_at TIMESTAMP -- Inserted At -- Timestamp when the record was inserted into the database,
  os_release_install_date TIMESTAMP -- OS Release Install Date -- Date when the operating system was installed,
  events_timestamp TIMESTAMP -- Events Timestamp -- Timestamp of the last security event,
  is_retired BOOLEAN -- Retired -- Indicates if the asset has been retired,
  raw_created_at TIMESTAMP -- Raw Created At -- Timestamp when the raw data was first created,
  store_created_at TIMESTAMP -- Store Created At -- Timestamp when the record was created in the store,
  store_updated_at TIMESTAMP -- Store Updated At -- Timestamp when the record was last updated in the store,
  process_id VARCHAR -- Process ID -- Unique identifier for the data processing job,
  last_processed TIMESTAMP -- Last Processed -- Timestamp when the asset was last processed,
  is_stale BOOLEAN -- Stale -- Indicates if the asset data is stale or outdated
);
