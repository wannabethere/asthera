CREATE TABLE actlabel_sumtotal (
  actlabel_pk BIGINT -- Activity Label Primary Key -- The unique primary key for an activity type. This identifier is referenced by the 'activitylabelfk' in the main activity table to categorize each learning activity.,
  actlabel_name TEXT -- Activity Label Name -- The official, user-facing name of the activity type or category (e.g., 'Virtual Classroom', 'Assessment', 'Webinar').,
  labeldesc TEXT -- Label Description -- A detailed description of the activity type, explaining its purpose or what it represents.,
  icon TEXT -- Icon -- A reference to a graphical icon used in the user interface to visually represent the activity type.,
  createddate_ts TIMESTAMP -- Created Date Timestamp -- The exact date and time when the activity type was first defined in the system.
);
