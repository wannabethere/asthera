2026-02-04 21:35:21,410 - app.indexing.ddl_utils - INFO - Generated DDL for tbl_tmx_userrequiredact_sumtotal: -- This table tracks required learning assignments for users. It contains all mandatory and recommended learning activities assigned to specific users, including due dates, completion status, and assignm...
CREATE TABLE tbl_tmx_userrequiredact_sumtotal (
  empfk BIGINT -- Employee Foreign Key -- Foreign key reference to the person_sumtotal table, linking user activities to specific employees.,
  activityfk BIGINT -- Activity Foreign Key -- Foreign key referencing the activity_sumtotal table associated with user-required actions.,
  reqstate BIGINT -- Request State -- Indicates the current state of a user-required action in the system. THe value is 1 for active and 0 for inactive.,
  notifstatus BIGINT -- Notification Status -- Status of the notification related to user-required activities.,
  reqstatus TEXT -- Request Status -- Indicates the current status of user's activity-assignment. This has ENrolled, Assigned, In Progress, Completed, Overdue, Expired.,
  plandate TIMESTAMP -- Plan Date -- The primary status of the user's assignment, indicating their progress (e.g., 'Assigned', 'In Progress', 'Overdue', 'Completed').,
  duedate TIMESTAMP -- Due Date -- The deadline by which the user is required to complete this learning assignment.,
  expirationdate TIMESTAMP -- Expiration Date -- The date when a user-required action is set to expire. Referenced as Expiration date.,
  notif_plandate TIMESTAMP -- Notification Planned Date -- The date when a notification is planned to be sent, represented as a string in timestamp format without time zone.,
  notif_duedate TEXT -- Notification Due Date -- The date by which a notification related to user-required activities is due.,
  issatisfied BIGINT -- Is Satisfied -- Indicates whether the user is satisfied with the activity or requirement.,
  isrequired BIGINT -- Is Required -- Indicates whether a specific activity is required for the user.,
  iscertification BIGINT -- Is Certification -- Indicates whether whether the activity is a certification or not.,
  lstupd TIMESTAMP -- Last Updated -- Timestamp indicating the last time the record was updated.
);
