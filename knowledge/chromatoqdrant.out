2026-02-04 21:34:49,393 - app.indexing.ddl_utils - INFO - Generated DDL for ComplianceRisk_Activity: -- Gold layer table containing activity-level aggregated compliance risk metrics enabling content effectiveness analysis, vendor evaluation, and activity-specific improvement strategies.
CREATE TABLE ComplianceRisk_Activity (
  activityRiskId string NOT NULL -- Activityriskid -- Unique identifier for activity-level aggregated risk record.,
  assessmentDate date NOT NULL -- Assessmentdate -- Date of the activity-level risk assessment.,
  loId string NOT NULL -- Loid -- Reference to the learning activity.,
  activityName string NOT NULL -- Activityname -- Name of the compliance training activity.,
  activityType string NOT NULL -- Activitytype -- Type/category of the compliance activity.,
  totalAssignments bigint NOT NULL -- Totalassignments -- Total number of users assigned to this activity.,
  avgRiskScore double NOT NULL -- Avgriskscore -- Average composite risk score for this activity.,
  medianRiskScore double NOT NULL -- Medianriskscore -- Median composite risk score for this activity.,
  riskScoreVariance double NOT NULL -- Riskscorevariance -- Variance in risk scores across users for this activity.,
  criticalCount bigint NOT NULL -- Criticalcount -- Number of users with critical risk for this activity.,
  highCount bigint NOT NULL -- Highcount -- Number of users with high risk for this activity.,
  overdueCount bigint NOT NULL -- Overduecount -- Number of overdue assignments for this activity.,
  completionRate double NOT NULL -- Completionrate -- Percentage of users who completed this activity.,
  avgDaysToComplete double -- Avgdaystocomplete -- Average time users take to complete this activity (days).,
  estimatedDuration bigint -- Estimatedduration -- Estimated duration of the activity (minutes).,
  firstAttemptSuccessRate double -- Firstattemptsuccessrate -- Percentage of users who passed on first attempt.,
  avgAttempts double -- Avgattempts -- Average number of attempts before completion.,
  activityRank bigint NOT NULL -- Activityrank -- Rank of activity by avgRiskScore (1 = lowest risk/best).,
  escalationRequiredCount bigint NOT NULL -- Escalationrequiredcount -- Number of assignments requiring escalation for this activity.,
  activityTrend string -- Activitytrend -- Risk trend direction for this activity (7-day comparison).,
  provider string -- Provider -- Training content provider or vendor.,
  contentReviewFlag string NOT NULL -- Contentreviewflag -- Indicates if activity content needs review.,
  interventionStrategy string -- Interventionstrategy -- Recommended intervention approach for this activity.
);
