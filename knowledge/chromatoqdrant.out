2026-02-04 21:34:42,207 - app.indexing.ddl_utils - INFO - Generated DDL for AttritionRisk_Silver: -- TIME SERIES Silver layer table containing row-level attrition risk assessments tracked daily over time. Each employee is assessed daily to monitor engagement trends, behavioral changes, and flight ris...
CREATE TABLE AttritionRisk_Silver (
  attritionRiskId string NOT NULL -- Attritionriskid -- Unique identifier for each attrition risk assessment record.,
  userId string NOT NULL -- Userid -- Reference to the user from User_csod table.,
  assessmentDate timestamp NOT NULL -- Assessmentdate -- Timestamp when the attrition risk assessment was calculated.,
  attritionRiskScore double NOT NULL -- Attritionriskscore -- Overall composite attrition risk score combining impact and likelihood (0-100).,
  attritionImpactScore double NOT NULL -- Attritionimpactscore -- Severity of organizational impact if this employee leaves (0-100).,
  attritionLikelihoodScore double NOT NULL -- Attritionlikelihoodscore -- Probability that this employee will leave the organization (0-100).,
  riskCategory string NOT NULL -- Riskcategory -- Categorical classification of attrition risk level based on attritionRiskScore.,
  tenureMonths bigint NOT NULL -- Tenuremonths -- Employee tenure in months since start date.,
  tenureRiskBand string NOT NULL -- Tenureriskband -- Risk classification based on tenure vulnerability periods.,
  learningEngagementScore double NOT NULL -- Learningengagementscore -- Employee engagement with learning activities (0-100).,
  complianceCompletionRate double NOT NULL -- Compliancecompletionrate -- Historical compliance training completion rate (0-100).,
  lastLoginDays bigint -- Lastlogindays -- Number of days since user last logged into the LMS.,
  overdueCourseCount bigint NOT NULL -- Overduecoursecount -- Number of overdue training assignments for this user.,
  managerChangeCount bigint NOT NULL -- Managerchangecount -- Number of manager changes in the last 12 months.,
  trainingInvestment double -- Traininginvestment -- Total investment in employee training over last 12 months.,
  positionLevel string NOT NULL -- Positionlevel -- Employee position level in organizational hierarchy.,
  directReportCount bigint NOT NULL -- Directreportcount -- Number of direct reports managed by this employee.,
  retentionPriority string NOT NULL -- Retentionpriority -- Retention action priority based on risk and impact.,
  hrEscalation string NOT NULL -- Hrescalation -- Flag indicating if HR/manager notification is required.,
  riskTrend string -- Risktrend -- Trend direction of attrition risk over the last 30 days.,
  retentionActions string -- Retentionactions -- Recommended retention strategies for this employee.
);
