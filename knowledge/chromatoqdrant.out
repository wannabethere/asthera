  completionDate timestamp -- Completiondate -- Date when the task was completed, represented as a timestamp without time zone.,
  expirationDate timestamp -- Expirationdate -- The date when a performance task or evaluation expires.,
  stepDueDate timestamp -- Stepduedate -- The date by which a specific step in the performance task is due.,
  stepSubmissionDate timestamp -- Stepsubmissiondate -- The date when the step was submitted in the performance evaluation process.
);
