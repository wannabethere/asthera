CREATE TABLE organization_sumtotal (
  organizationpk BIGINT -- Organization Primary Key -- Unique identifier for organizations within the organization_sumtotal table.,
  code TEXT -- Code -- A textual code representing the organization within the system.,
  name TEXT -- Organization Name -- The name of the organization as recorded in the system.,
  parentorganizationfk BIGINT -- Parent Organization Foreign Key -- Foreign key referencing the parent organization in the organization hierarchy.,
  hierarchyfk BIGINT -- Hierarchy Foreign Key -- Foreign key that references the hierarchy of organizations within the organization structure.,
  orgtypecode BIGINT -- Organization Type Code -- Code representing the type of organization.,
  lveelval BIGINT -- Level Value -- Column lveelval,
  orgdomainind BIGINT -- Organization Domain Indicator -- Indicates the domain associated with the organization, represented as a string.,
  contactpersonfk BIGINT -- Contact Person Foreign Key -- Foreign key referencing the contact person associated with the organization.,
  contactemail TEXT -- Contact Email -- Email address for contacting the organization.,
