2026-02-04 21:35:29,414 - app.indexing.ddl_utils - INFO - Generated DDL for tbl_tmx_activity_sumtotal: -- This table defines the learning activities and courses available in the SumTotal Learn platform. It contains the master catalog of all learning content including course details, settings, and configur...
CREATE TABLE tbl_tmx_activity_sumtotal (
  activity_pk BIGINT -- Activity Primary Key -- This column provides a unique, system-generated identifier for each learning activity. It serves as the primary key for this table and is the essential link to connect activity information with related details in other tables, such as attempts,assignments,registrations etc.,
  activityname TEXT -- Activity Name -- This column contains the official title of the learning activity. It serves as the primary descriptive label for the course or training throughout the system.,
  activitylabelfk BIGINT -- Activity Label Foreign Key -- A foreign key that references the Actlable table to define the activity's unique type. This link classifies the activity's Type within the system.,
  prntactfk BIGINT -- Parent Activity Foreign Key -- A self-referencing foreign key that links an activity to its parent, creating a structured hierarchy within this table. This is primarily used to define collections, such as a curriculum (parent) that contains a set of individual courses (children).,
  code TEXT -- Code -- The unique code used to identify each activity.,
  ccenter BIGINT -- Center -- Column representing whether collaboration center is enabled or not for the activity.,
  activitydesc TEXT -- Activity Description -- A textual description of the activity, providing details about what the activity entails.,
  activitydescfmt TEXT -- Activity Description Format -- Format of the activity description, which may include HTML or other markup.,
  active BIGINT -- Active -- Indicates whether the activity is currently active or not.,
  openforreg BIGINT -- Open for Registration -- Indicates whether the activity is open for registration.,
  noregreqd BIGINT -- No Registration Required -- Indicates whether registration is required for the activity.,
  maxattempts BIGINT -- Max Attempts -- Maximum number of attempts allowed for a specific activity.,
  maxattemptsperparent BIGINT -- Max Attempts Per Parent -- Maximum number of attempts allowed per parent activity.,
  cancelled BIGINT -- Cancelled -- Indicates whether an activity has been cancelled.,
  private BIGINT -- Private -- Column indicating whether the activity is private or not.,
  empnotesfmt TEXT -- Employee Notes Format -- Format for employee notes stored in the database, allowing for structured text representation.,
  instrnotesfmt TEXT -- Instructor Notes Format -- Format for instructor notes associated with activities.
);
