2026-02-04 21:34:31,119 - app.indexing.ddl_utils - INFO - Generated DDL for Transcript_csod: -- This table contains detailed records of employee learning activities, including completion status, scores, and timestamps for various training events.
CREATE TABLE Transcript_csod (
  loID string -- Loid -- Identifier for learning objects in the Cornerstone Learn system.,
  userID string -- Userid -- Identifier for users in the system, representing each learner's unique account.,
  isCompleted string -- Iscompleted -- Indicates whether the training activity has been completed by the learner.,
  isOverdue string -- Isoverdue -- Indicates whether a training assignment is overdue based on the due date.,
  isAssigned string -- Isassigned -- Indicates whether a training module is assigned to a user.,
  score bigint -- Score -- Column representing the performance score of a learner in the training module.,
  success string -- Success -- Indicates whether the learner successfully completed the training module.,
  timeSpent bigint -- Timespent -- Duration of time spent by the user on a specific learning activity, recorded in a VARCHAR format representing a numeric value.,
  satisfiedLate string -- Satisfiedlate -- Indicates whether the learner was satisfied with the training completed after the due date.,
  trainingStatus string -- Trainingstatus -- Indicates the current status of the training for a user.,
  cancellationDate string -- Cancellationdate -- Date when the training or learning activity was cancelled.,
  registrationDate timestamp -- Registrationdate -- The date when the user registered for the training or course.,
  attemptStartDate timestamp -- Attemptstartdate -- The date when the learning attempt started, represented as a timestamp without time zone.,
  completionDate timestamp -- Completiondate -- The date when the training or learning activity was completed by the user.,
  assignedDate timestamp -- Assigneddate -- The date when the training or learning activity was assigned to the user.,
  dueDate timestamp -- Duedate -- The date by which a training or compliance activity must be completed.,
  expiryDate timestamp -- Expirydate -- The date when the training or compliance activity expires.
);
