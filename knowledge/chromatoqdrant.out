CREATE TABLE persondomain_sumtotal (
  personfk BIGINT -- Person Foreign Key -- Foreign key reference to the person entity to get person details.,
  domainfk BIGINT -- Domain Foreign Key -- Foreign key referencing the organization table to get domain details.,
  rolefk BIGINT -- Role Foreign Key -- Foreign key referencing the role table to get role details.,
  isprimary BIGINT -- Is Primary -- Indicates whether the current domain is primary for the person.,
  createddate TIMESTAMP -- Created Date -- Timestamp indicating when the record was created in the Sumtotal Learn system.,
  deleted BIGINT -- Deleted Flag -- Indicates whether the record has been marked as deleted in the Sumtotal Learn system.,
  createdby TEXT -- Created By -- Column indicating the user or system that created the record in the Sumtotal Learn system.,
  modifieddate TIMESTAMP -- Modified Date -- Timestamp indicating when the record was last modified in the Sumtotal Learn system.,
  modifiedby TEXT -- Modified By -- Column indicating the user who last modified the record in the Sumtotal Learn system.
);
