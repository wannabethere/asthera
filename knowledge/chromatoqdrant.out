2026-02-04 21:34:45,179 - app.indexing.ddl_utils - INFO - Generated DDL for ComplianceRisk_Silver: -- TIME SERIES Silver layer table containing row-level compliance risk assessments tracked daily over time. Each user-activity assignment is assessed daily to monitor completion progression, risk evoluti...
CREATE TABLE ComplianceRisk_Silver (
  riskId string NOT NULL -- Riskid -- Unique identifier for each compliance risk assessment record.,
  userId string NOT NULL -- Userid -- Reference to the user from User_csod table.,
  loId string NOT NULL -- Loid -- Reference to the learning activity from Activity_csod table.,
  assessmentDate timestamp NOT NULL -- Assessmentdate -- Timestamp when the risk assessment was calculated.,
  riskScore double NOT NULL -- Riskscore -- Overall composite risk score combining impact and likelihood (0-100).,
  impactScore double NOT NULL -- Impactscore -- Severity of consequences if compliance training is not completed (0-100).,
  likelihoodScore double NOT NULL -- Likelihoodscore -- Probability that the compliance training will not be completed on time (0-100).,
  riskCategory string NOT NULL -- Riskcategory -- Categorical classification of risk level based on riskScore.,
  daysUntilDue bigint -- Daysuntildue -- Number of days remaining until the training due date (negative if overdue).,
  daysSinceAssigned bigint -- Dayssinceassigned -- Number of days elapsed since the training was assigned.,
  completionPercentage double -- Completionpercentage -- Progress towards completion expressed as a percentage (0-100).,
  userCompletionRate double -- Usercompletionrate -- Historical completion rate for this user across all compliance trainings (0-100).,
  avgDaysToComplete double -- Avgdaystocomplete -- User's historical average time to complete compliance trainings (in days).,
  managerEscalation string NOT NULL -- Managerescalation -- Flag indicating if manager notification is required.,
  previousAttempts bigint -- Previousattempts -- Number of previous incomplete attempts on this training.,
  lastLoginDays bigint -- Lastlogindays -- Number of days since user last logged into the LMS.,
  divisionalComplianceRate double -- Divisionalcompliancerate -- Current compliance rate for the user's division (0-100).,
  riskTrend string -- Risktrend -- Trend direction of risk over the last 7 days.,
  mitigationActions string -- Mitigationactions -- Recommended actions to reduce compliance risk.
);
