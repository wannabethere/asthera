CREATE TABLE person_sumtotal (
  personpk BIGINT -- Person Primary Key -- Unique identifier for each person in the person_sumtotal table.,
  personguid TEXT -- Person GUID -- A unique identifier for individuals in the person_sumtotal table.,
  lastname TEXT -- Last Name -- Column representing the last name of a person.,
  firstname TEXT -- First Name -- The first name of the person, represented as a text string.,
  middlename TEXT -- Middle Name -- The middle name of a person, stored as a variable character string.,
  fullname TEXT -- Full Name -- The full name of the person, combining first, middle, and last names.,
  active BIGINT -- Active Status -- Indicates whether a person is currently active in the system.,
  gendercode TEXT -- Gender Code -- Column representing the gender of a person, stored as a text value.,
  birthdate TIMESTAMP -- Birthdate -- The date of birth of the person, stored as a string in the format YYYY-MM-DD.,
  companycd TEXT -- Company Code -- A code representing the company associated with a person.,
  companyname TEXT -- Company Name -- The name of the company associated with the person.,
  startdate TIMESTAMP -- Start Date -- The date when a person record becomes effective, represented as a string in the format YYYY-MM-DD.,
  enddate TIMESTAMP -- End Date -- The date when a person's record is considered inactive or no longer valid.,
  deleted BIGINT -- Deleted Indicator -- Indicates whether a person record has been deleted.,
  createddate TEXT -- Created Date -- Date when the record was created in the system.
);
