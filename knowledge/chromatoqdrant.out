2026-02-04 21:34:54,894 - app.indexing.ddl_utils - INFO - Generated DDL for csod_training_records: -- Cornerstone OnDemand training records and completion tracking by the employee by division for the organization. This table covers completion rates by division, including how many assignments were comp...
CREATE TABLE csod_training_records (
  id INTEGER -- ID -- Employee ID as a primary key identifier for the employee,
  full_name VARCHAR -- Full Name -- Full name of the employee,
  user_id VARCHAR -- User ID -- ID of the user or Unique identifier for the employee,
  manager_name VARCHAR -- Manager Name -- Name of the employee's manager,
  training_type VARCHAR -- Training Type -- Type/category of the training,
  curriculum_title TEXT -- Curriculum Title -- Title of the curriculum or training program,
  training_title TEXT -- Training Title -- Specific title of the training activity,
  transcript_status VARCHAR -- Transcript Status -- Current status of the training transcript in. Values possible are Assigned / Satisfied / Expired / Waived and other possible values,
  division VARCHAR -- Division -- Business division name or department name that the employee belongs to,
  position VARCHAR -- Position -- Job position or role of the employee,
  assigned_date DATE -- Assigned Date -- Date when the training was assigned,
  completed_date DATE -- Completed Date -- Date when the training was completed by the employee. For any training related questions use this column,
  due_date DATE -- Due Date -- Due date for completing the training by the employee. For any training related questions use this column,
  satisfied_late BOOLEAN -- Satisfied Late -- Indicator if training was completed after due date by the employee,
  created_at TIMESTAMP -- Created At -- Timestamp when the record was created,
  updated_at TIMESTAMP -- Updated At -- Timestamp when the record was last updated,
  is_completed BOOLEAN -- Is Completed -- Whether the training has been completed by the employee,
  is_overdue BOOLEAN -- Is Overdue -- Whether the training is past due and incomplete by the employee,
  completion_days INTEGER -- Completion Days -- Number of days from assignment to completion by the employee,
  days_overdue INTEGER -- Days Overdue -- Number of days past the due date by the employee,
  assignment_month INTEGER -- Assignment Month -- Month when training was assigned (for cohort analysis) by the employee,
  is_satisfied_late BOOLEAN -- Is Satisfied Late -- Boolean indicator for late completion by the employee
);
