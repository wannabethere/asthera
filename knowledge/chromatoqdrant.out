  position string -- Position -- The job title or role of the user within the organization.,
  division string -- Division -- Column representing the division within the organization to which a user belongs.,
  location string -- Location -- Column representing the geographical location of the user.,
  userStatus string -- Userstatus -- Indicates the current status of the user within the system.,
  lastLogindate date -- Lastlogindate -- The date when the user last logged into the system.,
  startDate date -- Startdate -- The date when the user started their learning activities.
);
