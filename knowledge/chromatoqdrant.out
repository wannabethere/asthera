CREATE TABLE employee_training_records (
  EmployeeName VARCHAR -- Employee Name -- Full name of the employee,
  EmployeeID VARCHAR -- Employee ID -- Unique identifier for the employee,
  EmployeeEmail VARCHAR -- Employee Email -- Email address of the employee,
  PrimaryDomain VARCHAR -- Primary Domain -- Primary domain/region of the employee,
  PrimaryOrganization VARCHAR -- Primary Organization -- Organization/Department of the employee,
  PrimaryJob VARCHAR -- Primary Job -- Job title/role of the employee,
  ManagerName VARCHAR -- Manager Name -- Name of the employee's manager,
  ActivityName VARCHAR -- Activity Name -- Name of the training activity,
  ActivityCode VARCHAR -- Activity Code -- Unique code for the training activity,
  ActivityType VARCHAR -- Activity Type -- Type of training activity,
  ActivityStartDate TIMESTAMP -- Activity Start Date -- Start date of the training activity,
  ActivityEndDate TIMESTAMP -- Activity End Date -- End date of the training activity,
  isCertification BOOLEAN -- Is Certification -- Whether the activity is a certification,
  TrainingStatus VARCHAR -- Training Status -- Current status of the training,
  AssignmentDate TIMESTAMP -- Assignment Date -- Date when the training was assigned,
  DueDate TIMESTAMP -- Due Date -- Due date for completing the training,
  ExpirationDate TIMESTAMP -- Expiration Date -- Expiration date of the training/certification,
  CompletionDate TIMESTAMP -- Completion Date -- Date when the training was completed,
  SatisfiedLate BOOLEAN -- Satisfied Late -- Whether the training was completed after the due date,
  isCompliant BOOLEAN -- Is Compliant -- Whether the employee is compliant with training requirements,
  isAssigned BOOLEAN -- Is Assigned -- Whether the training is assigned to the employee,
  assignment_mode VARCHAR -- Assignment Mode -- How the training was assigned (Self vs Manager)
);
