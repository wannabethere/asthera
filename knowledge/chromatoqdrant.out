CREATE TABLE ComplianceRisk_Monthly (
  monthlyRiskId string NOT NULL -- Monthlyriskid -- Unique identifier for monthly aggregated risk record.,
  year bigint NOT NULL -- Year -- Calendar year of the monthly assessment.,
  month bigint NOT NULL -- Month -- Month number (1-12).,
  monthStartDate date NOT NULL -- Monthstartdate -- First day of the month.,
  monthEndDate date NOT NULL -- Monthenddate -- Last day of the month.,
  quarter bigint NOT NULL -- Quarter -- Fiscal quarter (1-4).,
  avgMonthlyRiskScore double NOT NULL -- Avgmonthlyriskscore -- Average of daily risk scores across the month.,
  maxDailyRiskScore double NOT NULL -- Maxdailyriskscore -- Highest daily average risk score during the month.,
  minDailyRiskScore double NOT NULL -- Mindailyriskscore -- Lowest daily average risk score during the month.,
  riskScoreVolatility double NOT NULL -- Riskscorevolatility -- Standard deviation of daily risk scores within the month.,
  totalAssignments bigint NOT NULL -- Totalassignments -- Average daily total assignments across the month.,
  avgCriticalCount double NOT NULL -- Avgcriticalcount -- Average daily count of critical risk assignments.,
  avgHighCount double NOT NULL -- Avghighcount -- Average daily count of high risk assignments.,
  avgOverdueCount double NOT NULL -- Avgoverduecount -- Average daily count of overdue assignments.,
  totalCompletionsMonth bigint NOT NULL -- Totalcompletionsmonth -- Total number of training completions during the month.,
  monthlyCompletionRate double NOT NULL -- Monthlycompletionrate -- Percentage of assignments completed during the month.,
  avgEscalationRequired double NOT NULL -- Avgescalationrequired -- Average daily count of assignments requiring manager escalation.,
  monthOverMonthChange double -- Monthovermonthchange -- Percentage change in average risk score from previous month.,
  riskTrendMonth string -- Risktrendmonth -- Overall risk trend for the month.,
  complianceHealthScore double NOT NULL -- Compliancehealthscore -- Composite health score combining risk, completion rate, and overdue metrics (0-100).,
  benchmarkRisk double -- Benchmarkrisk -- Risk score at same month in previous year for year-over-year comparison.,
  yearOverYearChange double -- Yearoveryearchange -- Percentage change in risk score compared to same month previous year.,
  topRiskCategory string -- Topriskcategory -- Most common risk category for the month.,
  seasonalityFactor double -- Seasonalityfactor -- Seasonal adjustment factor based on historical patterns (0.5-2.0).
);
